---
import type { CollectionEntry } from 'astro:content';
import Base from '@/layouts/Base.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	prevPost?: CollectionEntry<'blog'>;
	nextPost?: CollectionEntry<'blog'>;
	seriesPosts?: CollectionEntry<'blog'>[];
};

const { title, description, pubDate, updatedDate, heroImage, prevPost, nextPost, seriesPosts, series } = Astro.props;
---

<Base {title} {description}>
	<article class="prose dark:prose-invert mx-auto max-w-4xl">
		<div class="hero-image">
			{heroImage && <img width={1020} height={510} src={heroImage} alt="" />}
		</div>
		<div class="prose-h1:mb-4">
			<div class="date text-gray-500 mb-2">
			    <time datetime={pubDate.toISOString()}>
					{pubDate.toLocaleDateString('en-us', {
						year: 'numeric',
						month: 'short',
						day: 'numeric',
					})}
				</time>
				{
					updatedDate && (
						<div class="last-updated-on italic">
							Last updated on <time datetime={updatedDate.toISOString()}>
								{updatedDate.toLocaleDateString('en-us', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								})}
							</time>
						</div>
					)
				}
			</div>
			<h1>{title}</h1>
			<hr />
		</div>
		<slot />

		{
			seriesPosts && (
				<div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
					<div class="mb-8">
						<h3 class="text-xl font-bold mb-4">More in this series ({series})</h3>
						<ul class="space-y-2 list-disc list-inside">
							{seriesPosts.map((post) => (
								<li>
									{post.data.title === title ? (
										<span class="font-bold text-gray-900 dark:text-gray-100">{post.data.title} (Current)</span>
									) : (
										<a href={`/blog/${post.slug}/`} class="text-blue-600 dark:text-blue-400 hover:underline">
											{post.data.title}
										</a>
									)}
								</li>
							))}
						</ul>
					</div>

					<div class="flex justify-between items-center gap-4">
						{prevPost ? (
							<a
								href={`/blog/${prevPost.slug}/`}
								class="flex-1 p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors text-left group"
							>
								<div class="text-sm text-gray-500 group-hover:text-gray-700 dark:text-gray-400 dark:group-hover:text-gray-200">
									← Previous
								</div>
								<div class="font-medium text-blue-600 dark:text-blue-400 group-hover:underline">
									{prevPost.data.title}
								</div>
							</a>
						) : (
							<div class="flex-1" />
						)}

						{nextPost ? (
							<a
								href={`/blog/${nextPost.slug}/`}
								class="flex-1 p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors text-right group"
							>
								<div class="text-sm text-gray-500 group-hover:text-gray-700 dark:text-gray-400 dark:group-hover:text-gray-200">
									Next →
								</div>
								<div class="font-medium text-blue-600 dark:text-blue-400 group-hover:underline">
									{nextPost.data.title}
								</div>
							</a>
						) : (
							<div class="flex-1" />
						)}
					</div>
				</div>
			)
		}
	</article>
</Base>
